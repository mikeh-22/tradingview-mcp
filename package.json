{
  "name": "tradingview-mcp",
  "version": "0.1.0",
  "description": "MCP server for TradingView alerts and watchlists",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tradingview-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "login": "node dist/login.js",
    "login:interactive": "node dist/login.js --interactive",
    "login:import": "node dist/login.js --import-cookies",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "playwright": "^1.48.0",
    "tough-cookie": "^4.1.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/tough-cookie": "^4.0.5",
    "typescript": "^5.6.0"
  }
}
